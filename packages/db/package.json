{
  "name": "@knext/db",
  "version": "0.1.0",
  "description": "Typed data SDK for knext apps — drizzle-orm over the scale-to-zero Postgres pools (getDb / getDbRO).",
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/getknext-dev/knext.git",
    "directory": "packages/db"
  },
  "homepage": "https://github.com/getknext-dev/knext#readme",
  "bugs": {
    "url": "https://github.com/getknext-dev/knext/issues"
  },
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    },
    "./schema": {
      "types": "./dist/schema.d.ts",
      "import": "./dist/schema.js",
      "default": "./dist/schema.js"
    },
    "./migrate": {
      "types": "./dist/migrate.d.ts",
      "import": "./dist/migrate.js",
      "default": "./dist/migrate.js"
    }
  },
  "knext": {
    "publicApi": {
      "doc": "docs/PUBLIC_API.md",
      "stability": "The @knext/db `.`, `./schema`, and `./migrate` subpaths are public and follow semver. `./schema` re-exports drizzle's pg-core builders; `./migrate` ships `defineDrizzleConfig()` (the `kn-next db migrate` runner lands on it in #242).",
      "public": [
        ".",
        "./schema",
        "./migrate"
      ],
      "internalPrefix": null
    }
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsc -w"
  },
  "files": [
    "dist"
  ],
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "dependencies": {
    "@knext/lib": "workspace:^",
    "drizzle-orm": "^0.45.2"
  },
  "peerDependencies": {
    "drizzle-kit": "^0.31.0",
    "drizzle-orm": "^0.45.2"
  },
  "peerDependenciesMeta": {
    "drizzle-kit": {
      "optional": true
    },
    "drizzle-orm": {
      "optional": true
    }
  },
  "devDependencies": {
    "@types/node": "^20.8.0",
    "@types/pg": "^8.15.6",
    "drizzle-kit": "^0.31.0",
    "pg": "^8.16.3",
    "typescript": "^5.2.2"
  }
}
