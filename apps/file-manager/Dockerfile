# Vinext Production Dockerfile with pnpm deploy optimization
# Using platformatic/node-caged for V8 pointer compression (cuts memory by ~50%)
FROM --platform=linux/amd64 platformatic/node-caged:25-alpine AS base
ENV PNPM_HOME="/pnpm"
ENV PATH="$PNPM_HOME:$PATH"
RUN npm install -g pnpm

FROM base AS builder
# Install dependencies and build the project
WORKDIR /app
COPY . .
RUN pnpm install --frozen-lockfile
RUN pnpm --filter file-manager build

# Use pnpm deploy to extract only the file-manager app and its production dependencies
# This creates a standalone folder with no dev dependencies or other workspace apps
RUN rm -rf /app/out && pnpm --filter file-manager --prod deploy --legacy /app/out

# Prune heavy unneeded dependencies from the production out/ folder
COPY scripts/prune-node-modules.js /app/scripts/prune-node-modules.js
RUN node /app/scripts/prune-node-modules.js /app/out/node_modules

FROM base AS runner
WORKDIR /app
ENV NODE_ENV=production
ENV PORT=3000

# Create node user and group (platformatic image doesn't include it by default)
RUN addgroup -g 1000 node && adduser -u 1000 -G node -s /bin/sh -D node

RUN apk add --no-cache su-exec
RUN mkdir -p /cache/bytecode && chown node:node /cache/bytecode

# Copy the isolated production output
# pnpm deploy places the app at the root of the output directory
COPY --from=builder /app/out /app

# Copy entrypoint script generated by kn-next
COPY --from=builder /app/apps/file-manager/dist/entrypoint.sh /entrypoint.sh
RUN chmod +x /entrypoint.sh

EXPOSE 3000

HEALTHCHECK --interval=30s --timeout=3s --start-period=5s --retries=3 \
    CMD wget --no-verbose --tries=1 --spider http://localhost:3000/api/health || exit 1

ENTRYPOINT ["/entrypoint.sh"]
