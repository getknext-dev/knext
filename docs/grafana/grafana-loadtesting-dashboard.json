{
  "dashboard": {
    "id": null,
    "uid": "kn-next-loadtest",
    "title": "kn-next: Load Testing",
    "tags": ["knative", "nextjs", "load-test", "kn-next"],
    "timezone": "browser",
    "schemaVersion": 39,
    "refresh": "5s",
    "panels": [
      {
        "title": "Active Replicas",
        "description": "Running file-manager pods (Knative autoscaling)",
        "type": "stat",
        "gridPos": { "h": 6, "w": 6, "x": 0, "y": 0 },
        "targets": [
          {
            "expr": "sum(kube_pod_status_phase{namespace=\"default\", phase=\"Running\", pod=~\"file-manager.*\"}) or sum(up{job=\"file-manager\"})",
            "legendFormat": "Active Pods"
          }
        ],
        "options": {
          "colorMode": "background",
          "graphMode": "area",
          "justifyMode": "auto"
        },
        "fieldConfig": {
          "defaults": {
            "color": { "mode": "thresholds" },
            "thresholds": {
              "steps": [
                { "color": "red", "value": null },
                { "color": "green", "value": 1 }
              ]
            }
          }
        }
      },
      {
        "title": "Throughput (RPS)",
        "description": "Total requests per second across all pods",
        "type": "timeseries",
        "gridPos": { "h": 6, "w": 9, "x": 6, "y": 0 },
        "targets": [
          {
            "expr": "sum(rate(http_server_request_duration_seconds_count{job=\"file-manager\"}[15s]))",
            "legendFormat": "Total RPS"
          }
        ],
        "fieldConfig": {
          "defaults": {
            "color": { "fixedColor": "green", "mode": "fixed" },
            "custom": {
              "drawStyle": "line",
              "lineInterpolation": "smooth",
              "fillOpacity": 20,
              "lineWidth": 2
            },
            "unit": "reqps"
          }
        }
      },
      {
        "title": "Error Rate",
        "description": "Percentage of 4xx + 5xx responses",
        "type": "stat",
        "gridPos": { "h": 6, "w": 4, "x": 15, "y": 0 },
        "targets": [
          {
            "expr": "sum(rate(http_server_request_duration_seconds_count{job=\"file-manager\", http_response_status_code=~\"[45].*\"}[1m])) / sum(rate(http_server_request_duration_seconds_count{job=\"file-manager\"}[1m])) * 100 or vector(0)",
            "legendFormat": "Error %"
          }
        ],
        "fieldConfig": {
          "defaults": {
            "unit": "percent",
            "color": { "mode": "thresholds" },
            "thresholds": {
              "steps": [
                { "color": "green", "value": null },
                { "color": "yellow", "value": 1 },
                { "color": "red", "value": 5 }
              ]
            }
          }
        },
        "options": { "colorMode": "background" }
      },
      {
        "title": "Avg Response Time",
        "description": "Average request duration across all pods",
        "type": "stat",
        "gridPos": { "h": 6, "w": 5, "x": 19, "y": 0 },
        "targets": [
          {
            "expr": "sum(rate(http_server_request_duration_seconds_sum{job=\"file-manager\"}[1m])) / sum(rate(http_server_request_duration_seconds_count{job=\"file-manager\"}[1m]))",
            "legendFormat": "Avg Response"
          }
        ],
        "fieldConfig": {
          "defaults": {
            "unit": "s",
            "color": { "mode": "thresholds" },
            "thresholds": {
              "steps": [
                { "color": "green", "value": null },
                { "color": "yellow", "value": 0.5 },
                { "color": "red", "value": 1 }
              ]
            }
          }
        },
        "options": { "colorMode": "background" }
      },
      {
        "title": "RPS by Status Code",
        "description": "Request rate broken down by HTTP status code",
        "type": "timeseries",
        "gridPos": { "h": 8, "w": 12, "x": 0, "y": 6 },
        "targets": [
          {
            "expr": "sum(rate(http_server_request_duration_seconds_count{job=\"file-manager\", http_response_status_code=~\"2.*\"}[15s]))",
            "legendFormat": "2xx"
          },
          {
            "expr": "sum(rate(http_server_request_duration_seconds_count{job=\"file-manager\", http_response_status_code=~\"3.*\"}[15s]))",
            "legendFormat": "3xx"
          },
          {
            "expr": "sum(rate(http_server_request_duration_seconds_count{job=\"file-manager\", http_response_status_code=~\"4.*\"}[15s]))",
            "legendFormat": "4xx"
          },
          {
            "expr": "sum(rate(http_server_request_duration_seconds_count{job=\"file-manager\", http_response_status_code=~\"5.*\"}[15s]))",
            "legendFormat": "5xx"
          }
        ],
        "fieldConfig": {
          "defaults": {
            "custom": {
              "fillOpacity": 30,
              "lineWidth": 2,
              "stacking": { "mode": "normal" }
            },
            "unit": "reqps"
          },
          "overrides": [
            {
              "matcher": { "id": "byName", "options": "2xx" },
              "properties": [{ "id": "color", "value": { "fixedColor": "green", "mode": "fixed" } }]
            },
            {
              "matcher": { "id": "byName", "options": "4xx" },
              "properties": [{ "id": "color", "value": { "fixedColor": "yellow", "mode": "fixed" } }]
            },
            {
              "matcher": { "id": "byName", "options": "5xx" },
              "properties": [{ "id": "color", "value": { "fixedColor": "red", "mode": "fixed" } }]
            }
          ]
        }
      },
      {
        "title": "Latency Percentile Bands (P50 → P99)",
        "description": "Response time percentiles — the band between P50 and P99 shows latency spread",
        "type": "timeseries",
        "gridPos": { "h": 8, "w": 12, "x": 12, "y": 6 },
        "targets": [
          {
            "expr": "histogram_quantile(0.99, sum(rate(http_server_request_duration_seconds_bucket{job=\"file-manager\"}[15s])) by (le))",
            "legendFormat": "p99"
          },
          {
            "expr": "histogram_quantile(0.95, sum(rate(http_server_request_duration_seconds_bucket{job=\"file-manager\"}[15s])) by (le))",
            "legendFormat": "p95"
          },
          {
            "expr": "histogram_quantile(0.90, sum(rate(http_server_request_duration_seconds_bucket{job=\"file-manager\"}[15s])) by (le))",
            "legendFormat": "p90"
          },
          {
            "expr": "histogram_quantile(0.50, sum(rate(http_server_request_duration_seconds_bucket{job=\"file-manager\"}[15s])) by (le))",
            "legendFormat": "p50"
          }
        ],
        "fieldConfig": {
          "defaults": {
            "unit": "s",
            "custom": {
              "drawStyle": "line",
              "lineInterpolation": "smooth",
              "fillOpacity": 15,
              "lineWidth": 2,
              "gradientMode": "opacity"
            }
          },
          "overrides": [
            {
              "matcher": { "id": "byName", "options": "p99" },
              "properties": [{ "id": "color", "value": { "fixedColor": "red", "mode": "fixed" } }]
            },
            {
              "matcher": { "id": "byName", "options": "p95" },
              "properties": [{ "id": "color", "value": { "fixedColor": "orange", "mode": "fixed" } }]
            },
            {
              "matcher": { "id": "byName", "options": "p50" },
              "properties": [{ "id": "color", "value": { "fixedColor": "green", "mode": "fixed" } }]
            }
          ]
        }
      },
      {
        "title": "Request Duration Heatmap",
        "description": "Distribution of request durations over time",
        "type": "heatmap",
        "gridPos": { "h": 8, "w": 24, "x": 0, "y": 14 },
        "targets": [
          {
            "expr": "sum(increase(http_server_request_duration_seconds_bucket{job=\"file-manager\"}[30s])) by (le)",
            "legendFormat": "{{ le }}",
            "format": "heatmap"
          }
        ],
        "options": {
          "calculate": false,
          "color": {
            "mode": "scheme",
            "scheme": "Spectral",
            "steps": 64,
            "reverse": true
          },
          "yAxis": { "unit": "s" }
        }
      },
      {
        "title": "Requests Per Pod",
        "description": "RPS per individual pod — helps identify load balancing issues",
        "type": "timeseries",
        "gridPos": { "h": 8, "w": 12, "x": 0, "y": 22 },
        "targets": [
          {
            "expr": "sum(rate(http_server_request_duration_seconds_count{job=\"file-manager\"}[15s])) by (instance)",
            "legendFormat": "{{ instance }}"
          }
        ],
        "fieldConfig": {
          "defaults": {
            "custom": {
              "fillOpacity": 10,
              "lineWidth": 2
            },
            "unit": "reqps"
          }
        }
      },
      {
        "title": "Event Loop Lag",
        "description": "Node.js event loop lag — high values indicate CPU-bound bottlenecks",
        "type": "timeseries",
        "gridPos": { "h": 8, "w": 12, "x": 12, "y": 22 },
        "targets": [
          {
            "expr": "max(nodejs_eventloop_lag_max_seconds{job=\"file-manager\"}) by (instance)",
            "legendFormat": "Lag {{ instance }}"
          }
        ],
        "fieldConfig": {
          "defaults": {
            "unit": "s",
            "color": { "mode": "palette-classic" },
            "custom": { "fillOpacity": 10, "lineWidth": 2 }
          }
        }
      },
      {
        "title": "CPU Usage Per Pod",
        "description": "CPU utilization percentage per pod",
        "type": "timeseries",
        "gridPos": { "h": 8, "w": 12, "x": 0, "y": 30 },
        "targets": [
          {
            "expr": "rate(process_cpu_seconds_total{job=\"file-manager\"}[1m])",
            "legendFormat": "{{ instance }}"
          }
        ],
        "fieldConfig": {
          "defaults": {
            "unit": "percentunit",
            "custom": { "fillOpacity": 10, "lineWidth": 2 }
          }
        }
      },
      {
        "title": "Memory Usage Per Pod",
        "description": "Resident memory per pod",
        "type": "timeseries",
        "gridPos": { "h": 8, "w": 12, "x": 12, "y": 30 },
        "targets": [
          {
            "expr": "process_resident_memory_bytes{job=\"file-manager\"}",
            "legendFormat": "{{ instance }}"
          }
        ],
        "fieldConfig": {
          "defaults": {
            "unit": "bytes",
            "custom": { "fillOpacity": 10, "lineWidth": 2 }
          }
        }
      }
    ]
  },
  "message": "Provisioned by kn-next",
  "overwrite": true
}
