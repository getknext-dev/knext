{
  "annotations": {
    "list": [
      {
        "builtIn": 1,
        "datasource": { "type": "grafana", "uid": "-- Grafana --" },
        "enable": true,
        "hide": true,
        "iconColor": "rgba(0, 211, 255, 1)",
        "name": "Annotations & Alerts",
        "type": "dashboard"
      }
    ]
  },
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "links": [],
  "panels": [
    {
      "title": "Pod Count Over Time",
      "description": "Number of file-manager pods in each phase (Pending, Running, Terminated)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": {
            "fillOpacity": 20,
            "lineWidth": 2,
            "spanNulls": false
          },
          "unit": "short"
        },
        "overrides": []
      },
      "targets": [
        {
          "expr": "count(kube_pod_info{pod=~\"file-manager.*\", namespace=\"default\"}) or vector(0)",
          "legendFormat": "Total Pods",
          "refId": "A"
        },
        {
          "expr": "count(kube_pod_status_phase{pod=~\"file-manager.*\", namespace=\"default\", phase=\"Running\"} == 1) or vector(0)",
          "legendFormat": "Running",
          "refId": "B"
        },
        {
          "expr": "count(kube_pod_status_phase{pod=~\"file-manager.*\", namespace=\"default\", phase=\"Pending\"} == 1) or vector(0)",
          "legendFormat": "Pending",
          "refId": "C"
        }
      ]
    },
    {
      "title": "Cold Start Duration (Startup Histogram)",
      "description": "Time from container start to serving first request (p50, p95, p99)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": { "fillOpacity": 10, "lineWidth": 2 },
          "unit": "s"
        },
        "overrides": []
      },
      "targets": [
        {
          "expr": "histogram_quantile(0.50, sum(rate(kn_next_startup_duration_seconds_bucket[5m])) by (le))",
          "legendFormat": "p50",
          "refId": "A"
        },
        {
          "expr": "histogram_quantile(0.95, sum(rate(kn_next_startup_duration_seconds_bucket[5m])) by (le))",
          "legendFormat": "p95",
          "refId": "B"
        },
        {
          "expr": "histogram_quantile(0.99, sum(rate(kn_next_startup_duration_seconds_bucket[5m])) by (le))",
          "legendFormat": "p99",
          "refId": "C"
        }
      ]
    },
    {
      "title": "Container Restarts",
      "description": "Container restart count per pod — restarts may indicate OOM or crash loops",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 8 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": { "fillOpacity": 10, "lineWidth": 2 },
          "unit": "short"
        },
        "overrides": []
      },
      "targets": [
        {
          "expr": "kube_pod_container_status_restarts_total{pod=~\"file-manager.*\", namespace=\"default\"}",
          "legendFormat": "{{ pod }}",
          "refId": "A"
        }
      ]
    },
    {
      "title": "Warm vs Cold Starts",
      "description": "Ratio of warm starts (cache hit) vs cold starts (no cache)",
      "type": "piechart",
      "gridPos": { "h": 8, "w": 6, "x": 12, "y": 8 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" }
        },
        "overrides": [
          {
            "matcher": { "id": "byName", "options": "Warm Starts" },
            "properties": [{ "id": "color", "value": { "fixedColor": "green", "mode": "fixed" } }]
          },
          {
            "matcher": { "id": "byName", "options": "Cold Starts" },
            "properties": [{ "id": "color", "value": { "fixedColor": "blue", "mode": "fixed" } }]
          }
        ]
      },
      "targets": [
        {
          "expr": "sum(kn_next_bytecode_cache_warm_start == 1) or vector(0)",
          "legendFormat": "Warm Starts",
          "refId": "A"
        },
        {
          "expr": "sum(kn_next_bytecode_cache_warm_start == 0) or vector(0)",
          "legendFormat": "Cold Starts",
          "refId": "B"
        }
      ]
    },
    {
      "title": "Pod Startup Time (Container Ready)",
      "description": "Time from pod creation to container ready state",
      "type": "stat",
      "gridPos": { "h": 8, "w": 6, "x": 18, "y": 8 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 1 },
              { "color": "red", "value": 3 }
            ]
          },
          "unit": "s"
        },
        "overrides": []
      },
      "targets": [
        {
          "expr": "histogram_quantile(0.95, sum(rate(kn_next_startup_duration_seconds_bucket[15m])) by (le))",
          "legendFormat": "p95 Startup",
          "refId": "A"
        }
      ],
      "options": {
        "reduceOptions": {
          "calcs": ["lastNotNull"]
        },
        "textMode": "value_and_name",
        "colorMode": "background"
      }
    },
    {
      "title": "Knative Desired vs Actual Pods",
      "description": "Autoscaler desired pods vs actually running pods",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 16 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": {
            "fillOpacity": 10,
            "lineWidth": 2,
            "drawStyle": "line",
            "stacking": { "mode": "none" }
          },
          "unit": "short"
        },
        "overrides": []
      },
      "targets": [
        {
          "expr": "autoscaler_desired_pods{service_name=\"file-manager\"} or vector(0)",
          "legendFormat": "Desired",
          "refId": "A"
        },
        {
          "expr": "autoscaler_actual_pods{service_name=\"file-manager\"} or vector(0)",
          "legendFormat": "Actual",
          "refId": "B"
        }
      ]
    },
    {
      "title": "Scale-to-Zero Events",
      "description": "Number of times pods scaled to zero and back up",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 16 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": {
            "fillOpacity": 20,
            "lineWidth": 2,
            "drawStyle": "bars"
          },
          "unit": "short"
        },
        "overrides": []
      },
      "targets": [
        {
          "expr": "changes(autoscaler_actual_pods{service_name=\"file-manager\"}[5m])",
          "legendFormat": "Scale Events (5m window)",
          "refId": "A"
        }
      ]
    },
    {
      "title": "Memory Usage During Startup",
      "description": "Resident memory per pod — useful for identifying memory overhead during cold starts",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 24 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": { "fillOpacity": 10, "lineWidth": 2 },
          "unit": "bytes"
        },
        "overrides": []
      },
      "targets": [
        {
          "expr": "process_resident_memory_bytes{job=\"file-manager\"}",
          "legendFormat": "{{ instance }}",
          "refId": "A"
        }
      ]
    },
    {
      "title": "CPU During Startup",
      "description": "CPU usage per pod — spikes indicate compilation or initialization overhead",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 24 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": { "fillOpacity": 10, "lineWidth": 2 },
          "unit": "percentunit"
        },
        "overrides": []
      },
      "targets": [
        {
          "expr": "rate(process_cpu_seconds_total{job=\"file-manager\"}[1m])",
          "legendFormat": "{{ instance }}",
          "refId": "A"
        }
      ]
    }
  ],
  "schemaVersion": 39,
  "tags": ["kn-next", "cold-start", "knative", "autoscaling"],
  "templating": {
    "list": [
      {
        "current": { "selected": false, "text": "Prometheus", "value": "Prometheus" },
        "hide": 0,
        "includeAll": false,
        "name": "DS_PROMETHEUS",
        "options": [],
        "query": "prometheus",
        "type": "datasource"
      }
    ]
  },
  "time": { "from": "now-30m", "to": "now" },
  "timepicker": {},
  "timezone": "",
  "title": "kn-next: Cold Start & Autoscaling",
  "uid": "kn-next-coldstart",
  "version": 1
}
