{
  "name": "knative-next-monorepo",
  "private": true,
  "packageManager": "pnpm@10.4.1",
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev",
    "lint": "biome check .",
    "format": "biome format --write .",
    "test": "vitest",
    "test:ui": "vitest --ui",
    "test:coverage": "vitest --coverage",
    "ci": "biome check . && vitest run --coverage",
    "generate": "turbo gen",
    "changeset": "changeset",
    "changeset:version": "changeset version",
    "changeset:status": "changeset status",
    "release": "changeset publish",
    "smoke:cli": "node scripts/smoke-pack-cli.mjs",
    "smoke:install": "node scripts/install-smoke.mjs"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.4",
    "@changesets/cli": "^2.31.0",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.1",
    "@turbo/gen": "^2.8.10",
    "@vitejs/plugin-react": "^5.1.2",
    "@vitest/coverage-v8": "^4.0.18",
    "@vitest/ui": "^4.0.16",
    "happy-dom": "^20.0.11",
    "jsdom": "^27.3.0",
    "minio": "^8.0.6",
    "tsup": "^8.5.1",
    "turbo": "latest",
    "vitest": "^4.0.16"
  },
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "dependencies": {
    "@next/env": "^16.1.1"
  },
  "pnpm": {
    "//overrides": "Trivy HIGH/CRITICAL remediation for the shipped file-manager image (#199; same discipline as the operator fix in #155: bump the deps, don't suppress). Chains: @knext/lib → @cerbos/grpc (grpc-js, protobufjs) + minio (fast-xml-parser 4); @knext/core → @google-cloud/storage (fast-xml-parser 5, retry-request → @types/request → form-data 2). Guarded by tests/supply-chain-workflow.test.ts.",
    "overrides": {
      "@grpc/grpc-js": ">=1.14.4 <2",
      "fast-xml-parser@4": ">=4.5.5 <5",
      "fast-xml-parser@5": ">=5.5.6 <6",
      "form-data@2": ">=2.5.6 <3",
      "lodash": ">=4.18.0 <5",
      "protobufjs": ">=7.6.1 <8"
    }
  },
  "lint-staged": {
    "*": [
      "biome check --write --no-errors-on-unmatched --files-ignore-unknown=true"
    ]
  }
}
