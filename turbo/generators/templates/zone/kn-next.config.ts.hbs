import type { KnativeNextConfig } from "@knext/core";

// NextApp Operator declarative configuration — see docs/QUICKSTART.md Step 4.
const config: KnativeNextConfig = {
  // App name — becomes the NextApp resource and Knative Service name.
  name: "{{ name }}",

  // Registry to push the image to (the app name is appended).
  registry: "ghcr.io/<your-user>",

  // Object storage for static assets; publicUrl is where browsers fetch them.
  storage: {
    provider: "gcs", // "gcs" | "s3" | "minio"
    bucket: "<your-assets-bucket>",
    publicUrl: "https://storage.googleapis.com/<your-assets-bucket>",
  },

  // Knative autoscaling. minScale: 0 (the default) keeps scale-to-zero on.
  // Beyond minScale/maxScale/cpu*/memory*, ScalingConfig also supports:
  //   containerConcurrency, poolMax, warmSchedule[], targetBurstCapacity,
  //   panicWindowPercentage, panicThresholdPercentage — see the "Scaling
  //   Configuration" section of the README for the full list. All optional;
  //   unset ones are omitted from the NextApp CR and the operator's own
  //   default applies.
  scaling: {
    minScale: 1,
    maxScale: 10,
    containerConcurrency: 100,
  },

  // Bring-your-own database binding (optional). knext provisions no
  // database — this only binds an EXISTING Secret's DSN into the app as
  // DATABASE_URL (+ optional roSecretRef -> DATABASE_URL_RO). See the
  // "Database Binding" section of the README. Uncomment and point at your
  // own Secret to use it:
  // database: {
  //   secretRef: { name: "<your-db-secret>" },
  // },
};

export default config;
